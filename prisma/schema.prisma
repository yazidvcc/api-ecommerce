// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  CUSTOMER
}

model User {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(100)
  email     String   @unique @db.VarChar(50)
  password  String?  @db.VarChar(255)
  phone     String?  @db.VarChar(15)
  token     String?  @db.VarChar(255)
  role      Role     @default(CUSTOMER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  carts   Cart[]
  reviews Review[]

  @@map("users")
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String    @db.VarChar(100)
  products Product[]

  @@map("categories")
}

enum ProductGender {
  MALE
  FEMALE
  UNISEX
}

model Product {
  id          Int           @id @default(autoincrement())
  category_id Int
  name        String        @db.VarChar(255)
  gender      ProductGender
  description String        @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  category        Category         @relation(fields: [category_id], references: [id], onDelete: NoAction, onUpdate: Cascade)
  productVariants ProductVariant[]
  productPhotos   ProductPhoto[]

  @@map("products")
}

model Color {
  id   Int    @id @default(autoincrement())
  name String @db.VarChar(100)

  productVariants ProductVariant[]
  productPhotos   ProductPhoto[]

  @@map("colors")
}

model Size {
  id    Int    @id @default(autoincrement())
  label String @db.VarChar(100)

  productVariants ProductVariant[]

  @@map("sizes")
}

model ProductVariant {
  id         Int      @id @default(autoincrement())
  product_id Int
  color_id   Int
  size_id    Int
  price      Int
  stock      Int      @db.SmallInt
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  color   Color   @relation(fields: [color_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  size    Size    @relation(fields: [size_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  carts      Cart[]
  reviews    Review[]

  @@map("product_variants")
}

model ProductPhoto {
  id         Int     @id @default(autoincrement())
  product_id Int
  color_id   Int?
  url        String  @db.VarChar(300)
  is_main    Boolean @default(false)

  product Product @relation(fields: [product_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  color   Color?  @relation(fields: [color_id], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@map("product_photos")
}

model Cart {
  id                 Int @id @default(autoincrement())
  user_id            Int
  product_variant_id Int
  quantity           Int @db.SmallInt

  user           User           @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  productVariant ProductVariant @relation(fields: [product_variant_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("carts")
}

model Review {
  id                 Int    @id @default(autoincrement())
  user_id            Int
  product_variant_id Int
  review             String @db.VarChar(255)
  star               Int    @db.SmallInt

  user           User           @relation(fields: [user_id], references: [id], onDelete: Cascade, onUpdate: Cascade)
  productVariant ProductVariant @relation(fields: [product_variant_id], references: [id], onDelete: Cascade, onUpdate: Cascade)

  @@map("reviews")
}

enum OrderStatus {
  PENDING
  SHIPPED
  DELIVERED
  CANCELLED
}

